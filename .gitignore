# =============================================================================
# .gitignore — clarify-engine-ai
# Order matters: general → specific → whitelist (negations at the end).
# Working directories MUST stay tracked: knowledge_base/sources/, test_data/,
# docs/, src/, configs/, prompts/.
# =============================================================================


# -----------------------------------------------------------------------------
# 1) Runtime artifacts (generated by the pipeline / vector store / logging)
# -----------------------------------------------------------------------------
chroma_data/
data/chroma/
logs/
output/
data/output/
reports/

# Incoming TZ payloads — folder is reserved for runtime drops, keep only .gitkeep.
data/incoming/*
!data/incoming/.gitkeep


# -----------------------------------------------------------------------------
# 2) Secrets & environment
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.key
*.pem
credentials.json
service_account.json


# -----------------------------------------------------------------------------
# 3) Python & dev artifacts
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Test & type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# Virtual environments
venv/
env/
.venv/

# Packaging / build output
*.egg-info/
dist/
build/
pip-wheel-metadata/


# -----------------------------------------------------------------------------
# 4) OS & IDE artifacts
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Desktop.ini
ehthumbs.db

# Editors & IDEs
.vscode/
.idea/
.cursor/
*.swp
*.swo
*~


# -----------------------------------------------------------------------------
# 5) Excel artifacts (allow tracked samples in working data directories)
# -----------------------------------------------------------------------------
*.xlsx
!test_data/**/*.xlsx
!knowledge_base/sources/**/*.xlsx


# -----------------------------------------------------------------------------
# 6) Explicit whitelist for working directories
#    Negations re-include directories that may have been caught by globs above.
# -----------------------------------------------------------------------------
!knowledge_base/sources/
!test_data/
!docs/
!configs/
!prompts/
