# =============================================================================
# Classification pipeline — batch "Анализ ТЗ" (BL-42, issue #170)
#   pipeline.fallback_providers: GigaChat → OpenRouter → Ollama
#   GigaChat is the RU-resident primary (NFR-04). DeepSeek is deprecated for
#   Pilot (paid-only) — set DEEPSEEK_API_KEY only if you re-enable the chain
#   in configs/llm_config.yaml.
# =============================================================================

# 1) GigaChat OAuth2 (RU-resident, primary)
#    Получить пару client_id / client_secret в личном кабинете Sber Studio.
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=

# 2) OpenRouter (free tier, secondary; only allowed with use_test_data_mode=true)
OPENROUTER_API_KEY=

# DeepSeek — deprecated for Pilot (paid-only, BL-42 issue #170).
# Provider config is retained in configs/llm_config.yaml but excluded from
# pipeline.fallback_providers and ui.chat_fallback_providers. Re-enable only
# with explicit budget approval.
# DEEPSEEK_API_KEY=

# YandexGPT — исключён из цепочки (2026-05, issue #64)
# YANDEXGPT_API_KEY=

# =============================================================================
# RAG / KB Test UI — chat "Консультация" (BL-42, issue #170)
#   ui.chat_fallback_providers: GigaChat → Ollama
# =============================================================================
# 3) Ollama (local offline reserve). The base URL must point at a running
#    daemon started via `ollama serve`; pull the model beforehand
#    (`ollama pull ...`).
OLLAMA_BASE_URL=http://localhost:11434
# Must match the model from `ollama pull` in docs/runbooks/arm-deployment-ivan.md.
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=180

# Flags
USE_TEST_DATA_MODE=true
STRICT_EMBEDDER=true
