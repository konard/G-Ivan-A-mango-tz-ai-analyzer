# =============================================================================
# Classification pipeline (existing — DeepSeek → GigaChat fallback)
# =============================================================================
# Primary MVP provider (free tier, no card required)
DEEPSEEK_API_KEY="записать_ключ"

# Fallback RU-resident provider (Pilot/Production)
GIGACHAT_API_KEY="записать_ключ"

# YandexGPT — исключён из цепочки (2026-05, issue #64)
# YANDEXGPT_API_KEY="записать_ключ"

# =============================================================================
# RAG / KB Test UI (issue #73 — GigaChat → OpenRouter → Ollama)
# =============================================================================
# 1) GigaChat OAuth2 — preferred over the prebuilt GIGACHAT_API_KEY above.
#    Получить пару client_id / client_secret в личном кабинете Sber Studio.
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=

# 2) OpenRouter — free-tier models like deepseek/deepseek-r1:free.
OPENROUTER_API_KEY=

# 3) Ollama (local fallback). The base URL must point at a running daemon
#    started via `ollama serve`; pull the model beforehand (`ollama pull ...`).
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Flags
USE_TEST_DATA_MODE=true
STRICT_EMBEDDER=true
